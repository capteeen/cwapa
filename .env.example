# Required for TikTok/Instagram (and best-quality YouTube) transcription.
# Works with any OpenAI-compatible Whisper provider's key:
#   OpenAI (paid): https://platform.openai.com/api-keys
#   Groq (free tier): https://console.groq.com/keys
OPENAI_API_KEY=

# To use Groq's free hosted Whisper instead of OpenAI, uncomment:
# WHISPER_API_URL=https://api.groq.com/openai/v1/audio/transcriptions

# Optional overrides
# WHISPER_MODEL=whisper-1            # auto: whisper-large-v3-turbo on Groq
# YT_DLP_PATH=/usr/local/bin/yt-dlp
# FFMPEG_PATH=/usr/bin/ffmpeg
# MAX_VIDEO_SECONDS=3600

# Rate limiting (per client IP, sliding window). Protects your Groq/Railway
# bills from abuse. Defaults: 20 light + 12 heavy requests per hour.
# RATE_LIMIT_WINDOW_MS=3600000
# RATE_LIMIT_MAX=20                  # summaries, moment search
# RATE_LIMIT_HEAVY_MAX=12           # transcription, downloads
# RATE_LIMIT_DISABLED=1             # set to 1 to turn limiting off entirely

# Instagram (and sometimes YouTube on cloud hosts) requires a logged-in
# session. Export cookies from your browser (e.g. the "Get cookies.txt"
# extension) and either point to the file:
# YT_DLP_COOKIES=/path/to/cookies.txt
# ...or, on hosts where you can't add files (Railway etc.), paste the file's
# base64-encoded content instead (run: base64 -w0 cookies.txt):
# YT_DLP_COOKIES_B64=
# ...or paste the raw cookies.txt content:
# YT_DLP_COOKIES_CONTENT=

# Writable cookie store. yt-dlp writes refreshed cookies back here on each
# successful request, extending their life. Point at a persistent volume so
# that renewal survives restarts (Railway: add a volume, e.g. /data):
# COOKIES_STORE_PATH=/data/cookies.txt

# Admin: set a secret to enable the /admin/cookies page, where you can paste
# fresh cookies without a redeploy. Leave unset to keep admin disabled.
# ADMIN_TOKEN=

# Optional: get a Discord/Slack webhook ping when YouTube blocks a download
# (i.e. cookies need refreshing).
# ALERT_WEBHOOK_URL=

# Optional: monthly proxy GB budget — get a webhook ping at 80% and 100%
# (visibility only; it doesn't cut off service). Pair with your proxy
# provider's own spending cap for a hard limit.
# PROXY_MONTHLY_GB=5

# Route yt-dlp through a proxy so requests look like ordinary home traffic
# and sidestep YouTube's datacenter-IP blocking (no cookies needed). Use a
# residential proxy (e.g. IPRoyal, Webshare). Any http/https/socks5 string:
# YT_DLP_PROXY=http://user:pass@geo.iproyal.com:12321
# Residential proxies bill per GB, and full videos are large. Set this to 1
# to skip the proxy on full-video downloads (keeping it for transcription,
# clips, and metadata) so big files don't run up your proxy bill:
# YT_DLP_PROXY_SKIP_DOWNLOADS=1
