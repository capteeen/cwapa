# Required for TikTok/Instagram (and best-quality YouTube) transcription.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional overrides
# WHISPER_MODEL=whisper-1
# YT_DLP_PATH=/usr/local/bin/yt-dlp
# MAX_VIDEO_SECONDS=3600

# Instagram often requires a logged-in session. Export cookies from your
# browser (e.g. the "Get cookies.txt" extension) and point to the file:
# YT_DLP_COOKIES=/path/to/cookies.txt
